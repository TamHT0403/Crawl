# ─── BẮT BUỘC ───────────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:password@localhost:5432/crawlengine"
# Lưu ý: Nếu mật khẩu có ký tự đặc biệt, cần URL-encode (vd: @ -> %40)
DATABASE_URL="postgresql://postgres:password@localhost:5432/crawlengine"

# Key giải mã tất cả secrets trong DB. KHÔNG ĐƯỢC MẤT!
# Nếu không set, dùng fallback key (CHỈ cho local dev)
ENCRYPTION_KEY=""

# ─── KHÔNG BẮT BUỘC ─────────────────────────────────────────────────────────
# Tất cả API keys, tokens, secrets được quản lý qua Settings UI
# và mã hoá AES-256-GCM trong Database.
#
# Các key sau có thể set ở đây để fallback nếu DB chưa có:
# OPENAI_API_KEY, OPENAI_MODEL, YOUTUBE_API_KEY,
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI,
# FB_EMAIL, FB_PASSWORD, FB_PAGE_ID, FB_PAGE_ACCESS_TOKEN,
# TIKTOK_ACCESS_TOKEN, TIKTOK_OPEN_ID,
# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM,
# TELEGRAM_BOT_TOKEN
